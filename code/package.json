{
  "name": "go-deps-explorer",
  "displayName": "Go Deps Explorer",
  "description": "Browse, explore, and navigate Go project dependencies directly in VS Code. Supports direct/indirect deps, standard library, replace directives, multi-project workspaces, and Cmd+Click jump tracking.",
  "keywords": ["go", "golang", "dependencies", "explorer", "go.mod", "module", "dependency tree", "stdlib", "replace", "workspace"],
  "version": "0.2.3",
  "publisher": "BaiLuoYan",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BaiLuoYan/go-deps-explorer.git"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/go.mod"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "goDepsExplorer",
          "name": "Go Dependencies",
          "contextualTitle": "Go Deps Explorer",
          "when": "goDepsExplorer.hasGoMod",
          "icon": "tree-icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "goDepsExplorer.refresh",
        "title": "Go Deps: Refresh Dependencies",
        "icon": "$(refresh)"
      },
      {
        "command": "goDepsExplorer.openFile",
        "title": "Go Deps: Open Dependency File (Read-only)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "goDepsExplorer.refresh",
          "when": "view == goDepsExplorer",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Go Deps Explorer",
      "properties": {
        "goDepsExplorer.handleReplace": {
          "type": "boolean",
          "default": true,
          "description": "Whether to handle replace directives in go.mod"
        },
        "goDepsExplorer.showIndirect": {
          "type": "boolean",
          "default": true,
          "description": "Whether to show indirect dependencies"
        },
        "goDepsExplorer.vendorFirst": {
          "type": "boolean",
          "default": false,
          "description": "Prefer vendor directory over GOPATH module cache"
        },
        "goDepsExplorer.lazyMode": {
          "type": "boolean",
          "default": false,
          "description": "Lazy mode: only show dependencies when navigating to their source code. Previously visited dependencies are preserved and restored on restart."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "test:unit": "npx tsx test/unit-tests.ts",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^18.19.0",
    "@types/sinon": "^17.0.3",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.56.0",
    "mocha": "^10.2.0",
    "sinon": "^17.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
